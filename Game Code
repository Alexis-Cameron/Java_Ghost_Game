                del rooms[current_room]['item']
            else:
                print('You cannot collect that here')
        elif direction == 'Get Medkit':
            if 'item' in rooms[current_room] and rooms[current_room]['item'] == 'Medkit':
                item_location = rooms[current_room]['item']
                print('You retrieved a:', item_location)
                inventory.append(item_location)
                del rooms[current_room]['item']
            else:
                print('You cannot collect that here')
        elif direction == 'Get Cross Necklace':
            if 'item' in rooms[current_room] and rooms[current_room]['item'] == 'Cross Necklace':
                item_location = rooms[current_room]['item']
                print('You retrieved a:', item_location)
                inventory.append(item_location)
                del rooms[current_room]['item']
            else:
                print('You cannot collect that here')
        elif direction == 'Get Flashlight':
            if 'item' in rooms[current_room] and rooms[current_room]['item'] == 'Flashlight':
                item_location = rooms[current_room]['item']
                print('You retrieved a:', item_location)
                inventory.append(item_location)
                del rooms[current_room]['item']
            else:
                print('You cannot collect that here')
        elif direction == 'Get Sage Stick':
            if 'item' in rooms[current_room] and rooms[current_room]['item'] == 'Sage Stick':
                item_location = rooms[current_room]['item']
                print('You retrieved a:', item_location)
                inventory.append(item_location)
                del rooms[current_room]['item']
            #Prints else statement if item is not item in that specific room
            else:
                print('You cannot collect that here')
        #Prints else statement for invalid commands and moves
        else:
            print('Invalid direction chosen or invalid command given, please try again.')
            print('Direction options: Go North, Go South, Go East, Go West, Exit game \n')
        # Creates Win/Loss option to complete game based on inventory items
        final_item = 'Flashlight'
        if len(inventory) >= 6 and current_room == 'Moroas Bedroom':
            if final_item in inventory:
                print('You see Moroa, and send him into the light with your inventory items')
                print('Congratulations you have won, you have sent the Spirit into the light!')
                print('Thank you for playing! You have exited the game.')
            #Ends game
            break
        elif len(inventory) < 6 and current_room == 'Moroas Bedroom':
            print('Sorry, you have been vanished by Moroa and lost the game.')
            print('Thank you for playing! Hope you enjoyed')
            #Ends game
            break


#Runs main function of game
if __name__ == '__main__':
    main()

